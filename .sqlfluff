[sqlfluff]
dialect = bigquery
templater = dbt
max_line_length = 120
exclude_rules = L016

[sqlfluff:indentation]
indented_joins = false
indent_unit = space
tab_space_size = 4

[sqlfluff:layout:type:comma]
spacing_before = touch
line_position = trailing

[sqlfluff:templater:dbt]
project_dir = ./dbt
profiles_dir = ./dbt
target = ci
